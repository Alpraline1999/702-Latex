\setCJKmainfont{SimSun}[AutoFakeBold=true]   % 设置主字体为 SimSun，并指定其粗体
\setCJKsansfont{SimHei}[AutoFakeBold=true]   % 设置无衬线字体为 SimHei，并指定其粗体 \sffamily
