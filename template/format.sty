% *********************************************
%                   设置排版
% *********************************************
\geometry{%
  a4paper, % 使用A4纸张
  top = 3.2cm, % 上边距
  bottom = 2cm, % 下边距
  left = 2.5cm, % 左边距
  right = 2cm, % 右边距
  headheight = 14.90433pt, % 页眉高度
  headsep = 0.7488cm, % 页眉与正文的距离为 2.0cm  =  top - headheight - headsep + topmargin（1pt  =  0.376mm）
  footskip = 0.8cm, % 页脚与正文的距离为 1.2cm  =  bottom - footskip
}
\addtolength{\topmargin}{2.90433pt}

% 使用 \raggedbottom 命令来允许页面底部不对齐
