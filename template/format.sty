\newlength{\mynewlen}
\newlength{\myspacelen}

\newcounter{enTitleLines}% 英文标题行数
\setcounter{enTitleLines}{1}% 默认为1行
% 绘制下划线
\newcommand{\widthline}[1]{% 控制下划线长度
  \renewcommand{\mystring}{#1}%
  \settowidth{\mylen}{#1}%
  \setlength{\mynewlen}{\dimexpr \mylen / 2\relax}%
  \setlength{\myspacelen}{\dimexpr \halflen - \mynewlen \relax}%
  \renewcommand{\mynewstring}{%
    \uline{%
      \phantom{\hspace*{\myspacelen}}%
      \mystring%
      \phantom{\hspace*{\myspacelen}}}}%
  \mynewstring%
}
\newlength{\wholelen}% 控制空白部分长度
\newcommand{\widthspace}[1]{%
  \renewcommand{\mystring}{#1}%
  \settowidth{\mylen}{#1}%
  \setlength{\myspacelen}{\dimexpr \wholelen - \mylen \relax}%
  \renewcommand{\mynewstring}{\mystring\phantom{\hspace*{\myspacelen}}}%
  \mynewstring%
}
