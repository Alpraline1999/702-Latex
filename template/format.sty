% 设置长表格环境
\newenvironment{mylongtable}[7]
{%
  \par
  \centering\small
  \captionof{table}{#2} % 题注
  \label{#3}
  \vspace*{-22pt}
  \begin{longtable}{#1} \\ % 标签
    #4 % 首页表头
    \endfirsthead
    #5 % 后续页表头
    \endhead
    #6 % 除最后一页外的表尾
    \endfoot
    #7 % 最后一页的表尾
    \endlastfoot
    % 表格内容
    }{%
  \end{longtable}
  \addtocounter{table}{-1}
  \vspace*{-10pt}
}

