% 设置页眉和页脚样式
\fancyhf{} % 清空当前设置
\renewcommand{\headrulewidth}{0pt} % 移除默认页眉下划线
% 设置页眉页脚字体：五号，宋体，单倍行距
\newcommand{\setheadersize}{\fontsize{10.5pt}{10.5pt}\selectfont}

\newcounter{total_page}
\AddToHook{shipout/after}{\stepcounter{total_page}}

\fancypagestyle{mainstyle}{%
  % 设置页眉双下划线
  \renewcommand\headrule{%
    \hrule height 0.8pt width\headwidth%
    \vskip 0.8pt%
    \hrule height 1.5pt width\headwidth%
  }%
  \ifthenelse{\boolean{@twoside}}{
    % 双面打印
    % 设置奇偶数页页眉
    \fancyhead[CO]{\setheadersize 中国舰船研究院\myDegree 士学位论文}%
    \fancyhead[CE]{\setheadersize \myCnTitle}%
    % 设置奇偶数页页脚
    \fancyfoot[RO]{\setheadersize \thepage}%
    \fancyfoot[LE]{\setheadersize \thepage}%
  }{
    % 单面打印
    % 页眉（动态判断奇偶页）
    \fancyhead[C]{%
      \setheadersize
      \ifodd\value{total_page}
        中国舰船研究院\myDegree 士学位论文%
      \else
        \myCnTitle%
      \fi
    }
    \fancyfoot[C]{\setheadersize \thepage}%
  }
}

% *********************************************
%                   设置创建奇数页
% *********************************************
% 创建新的奇数页
\newcommand{\newoddpage}{%
  \newpage%
  \ifthenelse{\boolean{@twoside}}{
    \unless\ifodd\value{page}%
      \thispagestyle{empty}%
      \mbox{}%
      \newpage%
    \else
    \fi
  }{}
}

