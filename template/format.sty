% *********************************************
% 每一章重置图片、表格、公式编号
\counterwithin{equation}{section}
\counterwithin{figure}{section}
\counterwithin{table}{section}

% 设置图片题注格式
\captionsetup[figure]{%
  font = small, % 设置图片题注字体
  labelfont = small, % 设置标签字体
  labelsep = none, % 设置标签和图片题注文本之间的分隔符为空格
  justification = centering, % 设置图片题注居中对齐
  singlelinecheck = false, % 设置单行图片题注居中对齐
  labelformat = simple, % 设置标签为数字
  skip = 3pt, % 设置标签上方距离
  belowskip = -15pt, % 设置标签下方距离
}
% 设置子图片题注格式
\captionsetup[subfigure]{%
  font = small, % 设置图片题注字体
  labelfont = small, % 设置标签字体
  labelsep = space, % 设置标签和图片题注文本之间的分隔符为空格
  justification = centering, % 设置图片题注居中对齐
  singlelinecheck = false, % 设置单行图片题注居中对齐
  labelformat = parens, % 设置标签为数字在括号中
  skip = 2pt, % 设置标签上方距离
  belowskip = -3pt, % 设置标签下方距离
}

