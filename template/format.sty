% 二级标题：1.1
\renewcommand{\thesubsection}{\arabic{section}.\arabic{subsection}}
% 三级标题：1.1.1
\renewcommand{\thesubsubsection}{\arabic{section}.\arabic{subsection}.\arabic{subsubsection}}

% 设置章节标题字体
% 一级标题：居中，黑体，小二（18pt）% 22.5
\titleformat{\section}[block]{\centering\sffamily \fontsize{18pt}{22.5pt}\selectfont}{\thesection}{0.5em}{}
% 二级标题：黑体，小三（15pt）% 18.75
\titleformat{\subsection}{\sffamily \fontsize{15pt}{18.75pt}\selectfont}{\thesubsection}{0.5em}{}
% 三级标题，黑体，四号（14pt）% 17.25
\titleformat{\subsubsection}{\sffamily \fontsize{14pt}{17.5pt}\selectfont}{\thesubsubsection}{0.5em}{}

% 设置章节标题段落间距
% 一级标题：左缩进0pt，段前6pt，段后6pt
\titlespacing*{\section}{0pt}{6pt}{6pt}
% 二级标题：左缩进0pt，段前6pt，段后6pt
\titlespacing*{\subsection}{0pt}{6pt}{6pt}
% 三级标题，左缩进0pt，段前0pt，段后0pt
\titlespacing*{\subsubsection}{0pt}{0pt}{0pt}

